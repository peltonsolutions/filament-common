{
  "name": "peltonsolutions/filament-common",
  "description": "A custom package for Filament that provides common enhancements used throughout peltonsolutions packages.",
  "keywords": [
    "peltonsolutions",
    "laravel",
    "filament"
  ],
  "homepage": "https://github.com/peltonsolutions/filament-common",
  "license": "MIT",
  "authors": [
    {
      "name": "Nathan Pelton",
      "email": "npelton@gmail.com",
      "homepage": "https://www.nathanpelton.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "filament/filament": "^5.0",
    "laravel/framework": "^11.0 || ^12.0 || ^13.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.94",
    "pestphp/pest": "^2.33 || ^3.0 || ^4.0",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "PeltonSolutions\\FilamentCommon\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PeltonSolutions\\FilamentCommon\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/pest"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "PeltonSolutions\\FilamentCommon\\FilamentCommonServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
